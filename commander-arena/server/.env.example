# ─── Commander Arena — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Required — your Anthropic API key from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Server port (default: 3001)
PORT=3001

# Environment: development | production
NODE_ENV=development

# Comma-separated list of allowed origins for CORS.
# In development this defaults to localhost:3000 and localhost:5173.
# In production set this to your actual domain:
#   ALLOWED_ORIGINS=https://commanderarena.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
